{
  "name": "hydra",
  "version": "0.1.0",
  "description": "Self-hostable x402 facilitator + multi-facilitator failover",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hydra": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch facilitator/server.ts",
    "start": "node dist/facilitator/server.js",
